{
  "name": "strava-time-machine",
  "private": true,
  "version": "1.0.0",
  "description": "Strava history analysis website (API + SPA)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.json && vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "mysql2": "^3.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
